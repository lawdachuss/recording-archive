{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@10.26.1",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"var f=require('fs');['package-lock.json','yarn.lock'].filter(function(p){return f.existsSync(p)}).forEach(function(p){f.unlinkSync(p)});var ua=process.env.npm_config_user_agent;if(!ua||!ua.startsWith('pnpm/')){console.error('Use pnpm instead');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "msw",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.27.3",
    "@rollup/rollup-win32-x64-msvc": "^4.61.1",
    "@tailwindcss/oxide-win32-x64-msvc": "4.3.0",
    "cross-env": "^10.1.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "pg": "^8.20.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "vercel": "^54.12.2"
  }
}
