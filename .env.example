# ── REQUIRED: Chaturbate cookies (get these from your browser after logging in) ──
COOKIES="your_cookies_here"
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# ── Streamtape ──
STREAMTAPE_LOGIN="your_streamtape_login"
STREAMTAPE_API_KEY="your_streamtape_api_key"

# ── VOESX ──
VOESX_API_KEY="your_voesx_api_key"

# ── SendCM ──
SENDCM_API_KEY="your_sendcm_api_key"

# ── BYSE ──
BYSE_API_KEY="your_byse_api_key"

# ── Supabase ──
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_API_KEY="your_supabase_api_key"
SUPABASE_ANON_KEY="your_supabase_anon_key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# ── API URL (optional, for different-domain API) ──
# When set, all API calls are prefixed with this URL.
# Leave empty for same-origin requests (default).
# Example: VITE_API_URL="https://your-api.vercel.app"
VITE_API_URL=""

# ── Mixdrop ──
MIXDROP_EMAIL="your_mixdrop_email"
MIXDROP_KEY="your_mixdrop_key"

# ── Database ──
DATABASE_URL="postgresql://user:password@host:5432/database"

# ── Redis (caching) ──
REDIS_URL="redis://default:password@host:6379"

# ── FFmpeg Path (automatically detected) ──
FFMPEG_PATH="C:\path\to\ffmpeg.exe"

# ── Ports ──
PORT=8080
BASE_PATH="/"
